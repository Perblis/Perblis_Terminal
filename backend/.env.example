# Terminal backend — environment variables (TSD §2.2)
# Copy to `.env` for local dev. Every var the settings read is listed here;
# CI fails if settings reference a var missing from this file.
# Absent integration keys in dev => console/log fallback, never a crash.

# --- Core ----------------------------------------------------------------
# postgis:// scheme so django-environ selects the GIS backend.
DATABASE_URL=postgis://postgres:postgres@localhost:5432/terminal
SECRET_KEY=dev-insecure-change-me
DEBUG=1
# Comma-separated. Prod sets real hosts from the platform env.
ALLOWED_HOSTS=*
CORS_ALLOWED_ORIGINS=http://localhost:3000
# Prod-only (settings.prod): force HTTPS redirect. Leave false behind a
# TLS-terminating proxy (Railway) so internal HTTP health checks don't loop.
SECURE_SSL_REDIRECT=false

# --- Ops Console security (TSD §7) ---------------------------------------
# Enforce django-otp TOTP 2FA on the Ops Console (Django admin). Default off in
# dev/CI; prod defaults ON. Enrol a device first: `manage.py enroll_totp <email>`.
ADMIN_2FA_REQUIRED=false
# Admin session cookie isolation (separate name + path). Defaults are usually fine.
ADMIN_SESSION_COOKIE_NAME=terminal_ops_sessionid
ADMIN_SESSION_COOKIE_PATH=/admin/

# Fernet key for encrypting supplier bank account numbers at rest.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=

# --- Email (dev: Mailpit over SMTP; unset => console backend) ------------
EMAIL_HOST=localhost
EMAIL_PORT=1025
# From-address for transactional email (welcome, OTP-less notices, reset).
DEFAULT_FROM_EMAIL=Terminal <contact@perblis.com>
# Base URL of the user-facing app, for links in emails (e.g. password reset).
FRONTEND_BASE_URL=http://localhost:3000

# --- Cloudflare R2 (media; public + private buckets) ---------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET=
R2_PUBLIC_BUCKET=terminal-public
R2_PRIVATE_BUCKET=terminal-private
R2_PUBLIC_BASE_URL=

# --- Payments (collect-only) ---------------------------------------------
# Pluggable provider (D-018, supersedes D-017): paystack (MVP) | bachs.
PAYMENT_PROVIDER=paystack

# Paystack (current MVP). Test keys from the dashboard; webhooks are signed
# HMAC-SHA512 over the raw body with the secret key (no separate webhook secret).
PAYSTACK_API_BASE=https://api.paystack.co
PAYSTACK_SECRET_KEY=
# Where Paystack redirects the payer after checkout (UX only; confirmation is
# webhook-driven). Defaults to the deployed Supplier Portal if unset.
PAYSTACK_CALLBACK_URL=https://terminal-portal.nwabueze.workers.dev/

# Bachs.io (D-017) — alternate provider, retained behind the gateway.
# BACHS_WEBHOOK_SECRET is the per-endpoint signing secret (not the API key).
BACHS_API_BASE=https://sandbox-api.bachs.io/v1
BACHS_SECRET_KEY=
BACHS_WEBHOOK_SECRET=

# --- Realtime / OTP / Email / Maps ---------------------------------------
# Recipient for the weekly Ops digest + reconciliation alerts (blank => the
# DEFAULT_FROM_EMAIL address). Cron: run_weekly_digest (weekly), run_daily_reconciliation (daily).
OPS_DIGEST_RECIPIENT=
# Fixed OTP for Playwright E2E runs only — honoured under DEBUG, refused loudly elsewhere.
E2E_FIXED_OTP=
ABLY_API_KEY=
TERMII_API_KEY=
TERMII_SENDER_ID=
RESEND_API_KEY=
LOCATIONIQ_KEY=

# --- Observability -------------------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=local

# --- Ops superuser seed (optional; read by `manage.py seed_superuser`) ----
# Set all three to auto-create the Ops superuser on deploy (idempotent).
SEED_SUPERUSER_EMAIL=
SEED_SUPERUSER_PHONE=
SEED_SUPERUSER_PASSWORD=
