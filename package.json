{
  "name": "terminal-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "tokens:build": "pnpm --filter @terminal/tokens build",
    "portal:dev": "pnpm --filter @terminal/portal dev",
    "portal:build": "pnpm --filter @terminal/portal build",
    "portal:deploy": "pnpm --filter @terminal/portal run deploy",
    "portal:deploy:preview": "pnpm --filter @terminal/portal run deploy:preview"
  },
  "pnpm": {
    "overrides": {
      "react": "19.2.3",
      "react-dom": "19.2.3"
    }
  }
}
